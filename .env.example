# ============================================================
# Soundprint Docker Compose 环境变量
# 复制为 .env 后可按演示环境修改实际值
# ============================================================

# MySQL 配置
MYSQL_ROOT_PASSWORD=rootpass123
MYSQL_DATABASE=soundprint
MYSQL_USER=soundprint
MYSQL_PASSWORD=soundprint123

# 宿主机文件存储目录：Docker 容器内会挂载为 /data/storage
SOUNDPRINT_STORAGE_PATH=D:/soundprint-storage

# 时区
TZ=Asia/Shanghai
